{
  "mcpServers": {
    "context-mode": {
      "command": "context-mode",
      "directTools": true
    },
    "code-review-graph": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/home/gc/development/code-review-graph",
        "code-review-graph",
        "serve"
      ],
      "type": "stdio"
    },
    "figma": {
      "command": "npx",
      "args": ["-y", "figma-developer-mcp", "--stdio"],
      "env": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      }
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp",
      "auth": "oauth"
    },
    "posthog": {
      "url": "https://mcp.posthog.com/mcp",
      "auth": "bearer",
      "bearerToken": "${POSTHOG_BEARER_TOKEN}"
    },
    "firebase": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "mcp"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect",
        "--userDataDir",
        "/home/gc/.config/chromium"
      ]
    },
    "directus": {
      "url": "https://dev-directus-tmn.globalswitchboard.io/mcp",
      "auth": "bearer",
      "bearerToken": "${DIRECTUS_DEV_API_KEY}"
    }
  }
}
